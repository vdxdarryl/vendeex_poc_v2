# .env.template
# VX-029-CAP-LLM: Self-Hosted Intelligence Layer
# Environment Variables
# 05/03/2026 | (c) 2026 Vendee Labs Limited
#
# INSTRUCTIONS:
# 1. Copy this file to .env in the same directory as docker-compose.yaml
# 2. Fill in every required value before running docker compose up
# 3. Never commit .env to version control
# 4. Keep a secure offline copy of all generated keys

# ------------------------------------------------------------
# HuggingFace
# Required for model weight downloads on first deployment.
# Subsequent restarts use model_cache volume -- token still required.
# Get from: https://huggingface.co/settings/tokens (Read permission)
# ------------------------------------------------------------
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN

# ------------------------------------------------------------
# Internal LLM API Key
# Used by vLLM to authenticate requests from the orchestrator.
# Generate a strong random string -- this never leaves the Pod.
# Example generation: openssl rand -hex 32
# ------------------------------------------------------------
VX_LLM_API_KEY=REPLACE_WITH_GENERATED_KEY

# ------------------------------------------------------------
# Operational Database
# Not active in PoC -- defaults are set in docker-compose.yaml.
# Fill in when connecting to a real operational database.
# ------------------------------------------------------------
VX_DB_HOST=localhost
VX_DB_PORT=5432
VX_DB_NAME=vendeex
VX_DB_USER=vendeex
VX_DB_PASSWORD=REPLACE_IF_USING_DB

# ------------------------------------------------------------
# External Product Search APIs
# Used by orchestrator for outbound product search only.
# All member-facing conversation handled by self-hosted Layer 3.
# Not required for initial stack validation -- leave blank to skip.
# ------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
